# Neon pooled connection string (same DB as web/)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Google AI Studio key (server-side only)
GEMINI_API_KEY=

# HS256 secret for JWT from Next.js proxy (≥32 random bytes, different from BETTER_AUTH_SECRET)
MAILCHAMP_JWT_SECRET=

# Server port (Render sets PORT automatically)
PORT=8080

# Gemini models — never use gemini-2.0/2.5-* for this account
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_FALLBACKS=gemini-3.1-flash-lite-preview
GEMINI_TEMPERATURE=0.4
GEMINI_MAX_RETRIES=6
GEMINI_REQUEST_DELAY_SECONDS=15
